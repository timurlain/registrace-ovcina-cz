@page "/organizace/hry/{gameId:int}/kralovstvi"
@attribute [Authorize(Policy = AuthorizationPolicies.StaffOnly)]

@inject KingdomAssignmentService KingdomAssignmentService

<PageTitle>Rozdělení do království</PageTitle>

@if (board is null)
{
    <p class="text-secondary">Načítám rozdělení do království...</p>
}
else
{
    <div class="mb-3">
        <a href="/admin/hry" class="text-decoration-none small">&larr; Zpět na správu her</a>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <h1 class="h4 mb-1">Rozdělení &mdash; @board.GameName</h1>
            <p class="text-secondary small mb-0">Přetáhněte hráče mezi království. Celkem: @TotalPlayerCount</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-success py-1 small" role="status">@statusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger py-1 small" role="alert">@errorMessage</div>
    }

    <div class="row g-2" id="kingdom-board">
        @* Unassigned column *@
        <div class="col">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-secondary text-white py-2 px-3"
                     data-kingdom-id=""
                     ondragover="event.preventDefault();" ondrop="handleDrop(event)">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong class="small">Nepřidělení</strong>
                        <span class="badge text-bg-light">@board.UnassignedPlayers.Count</span>
                    </div>
                </div>
                <div class="card-body p-1" style="max-height: 70vh; overflow-y: auto;"
                     data-kingdom-id=""
                     ondragover="event.preventDefault();" ondrop="handleDrop(event)">
                    @if (board.UnassignedPlayers.Count == 0)
                    {
                        <p class="text-muted small p-2 mb-0">Všichni přiděleni.</p>
                    }
                    else
                    {
                        @foreach (var player in board.UnassignedPlayers)
                        {
                            @RenderPlayerCard(player, null)
                        }
                    }
                </div>
            </div>
        </div>

        @* Kingdom columns *@
        @foreach (var kingdom in board.Kingdoms)
        {
            var avgAge = kingdom.Players.Count > 0
                ? Math.Round(kingdom.Players.Average(p => (double)(DateTime.UtcNow.Year - p.BirthYear)), 1)
                : 0;

            <div class="col">
                <div class="card shadow-sm h-100">
                    <div class="card-header py-2 px-3"
                         style="@GetKingdomHeaderStyle(kingdom.Color)"
                         data-kingdom-id="@kingdom.KingdomId"
                         ondragover="event.preventDefault();" ondrop="handleDrop(event)">
                        <div class="d-flex justify-content-between align-items-center">
                            <strong class="small">@kingdom.DisplayName</strong>
                            <span class="badge @GetCountBadgeClass(kingdom)">
                                @kingdom.CurrentCount / @kingdom.TargetCount
                            </span>
                        </div>
                        @if (kingdom.Players.Count > 0)
                        {
                            <div style="font-size:0.6rem; opacity:0.8;">⌀ @avgAge.ToString("0.0") let</div>
                        }
                    </div>
                    <div class="card-body p-1" style="max-height: 70vh; overflow-y: auto;"
                         data-kingdom-id="@kingdom.KingdomId"
                         ondragover="event.preventDefault();" ondrop="handleDrop(event)">
                        @if (kingdom.Players.Count == 0)
                        {
                            <p class="text-muted small p-2 mb-0">Zatím nikdo.</p>
                        }
                        else
                        {
                            @foreach (var player in kingdom.Players)
                            {
                                @RenderPlayerCard(player, kingdom)
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<form id="assign-form" method="post" action="/organizace/hry/@GameId/kralovstvi/pridelit" style="display:none;">
    <AntiforgeryToken />
    <input type="hidden" name="registrationId" id="assign-reg-id" />
    <input type="hidden" name="kingdomId" id="assign-kingdom-id" />
</form>

<script>
    function handleDragStart(e) {
        e.dataTransfer.setData('text/plain', e.currentTarget.dataset.registrationId);
        e.currentTarget.style.opacity = '0.5';
        setTimeout(() => { e.currentTarget.style.opacity = '1'; }, 300);
    }

    function handleDrop(e) {
        e.preventDefault();
        const regId = e.dataTransfer.getData('text/plain');
        const target = e.currentTarget.closest('[data-kingdom-id]') || e.currentTarget;
        const kingdomId = target.dataset.kingdomId || '';

        const form = document.getElementById('assign-form');
        document.getElementById('assign-reg-id').value = regId;
        document.getElementById('assign-kingdom-id').value = kingdomId;
        form.submit();
    }

    function reassignPlayer(selectEl, registrationId) {
        const kingdomId = selectEl.value;
        if (kingdomId === '' && selectEl.selectedIndex === 0) return; // "Přesunout..." placeholder
        const form = document.getElementById('assign-form');
        document.getElementById('assign-reg-id').value = registrationId;
        document.getElementById('assign-kingdom-id').value = kingdomId;
        form.submit();
    }
</script>

<style>
    .kingdom-card { cursor: grab; transition: box-shadow 0.15s; }
    .kingdom-card:active { cursor: grabbing; }
    .kingdom-card:hover { box-shadow: 0 2px 6px rgba(0,0,0,0.15); }
    .reassign-select { display: none; }
    .kingdom-card:hover .reassign-select { display: block; }
    .card-detail { display: none; }
    .kingdom-card:hover .card-detail { display: block; }
    [data-kingdom-id].drag-over { background: rgba(0,0,0,0.05); }
</style>

@code {
    private static readonly int CurrentYear = DateTime.UtcNow.Year;

    private RenderFragment RenderPlayerCard(PlayerCard player, KingdomColumn? currentKingdom) => __builder =>
    {
        <div class="kingdom-card border rounded px-2 py-1 mb-1 bg-light"
             draggable="true" data-registration-id="@player.RegistrationId"
             ondragstart="handleDragStart(event)">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-semibold" style="font-size:0.8rem;">@player.PersonName</span>
                <span class="text-muted" style="font-size:0.7rem;">@player.Age(CurrentYear) let</span>
            </div>
            <div style="font-size:0.7rem;" class="d-flex flex-wrap gap-1">
                @if (!string.IsNullOrWhiteSpace(player.GroupName))
                {
                    <span class="badge text-bg-secondary" style="font-size:0.6rem;">@player.GroupName</span>
                }
                @if (!string.IsNullOrWhiteSpace(player.PreferredKingdomName))
                {
                    <span class="badge text-bg-info" style="font-size:0.6rem;">pref: @player.PreferredKingdomName</span>
                }
                @if (!string.IsNullOrWhiteSpace(player.PreviousKingdomName))
                {
                    <span class="badge text-bg-warning" style="font-size:0.6rem;">minule: @player.PreviousKingdomName</span>
                }
            </div>
            <div class="card-detail" style="font-size:0.65rem; border-top: 1px solid #dee2e6; margin-top: 3px; padding-top: 3px;">
                @if (player.PlayerSubType.HasValue)
                {
                    <div><strong>Typ:</strong> @GetPlayerSubTypeLabel(player.PlayerSubType.Value)</div>
                }
                @if (!string.IsNullOrWhiteSpace(player.CharacterName))
                {
                    <div><strong>Postava:</strong> @player.CharacterName</div>
                }
                @if (!string.IsNullOrWhiteSpace(player.GuardianName))
                {
                    <div><strong>Zákonný zástupce:</strong> @player.GuardianName</div>
                }
                @if (!string.IsNullOrWhiteSpace(player.PersonNotes))
                {
                    <div><strong>Poznámka:</strong> @player.PersonNotes</div>
                }
                @if (!string.IsNullOrWhiteSpace(player.OrganizerNotes))
                {
                    <div><strong>Org. poznámky:</strong> @player.OrganizerNotes</div>
                }
                @if (!string.IsNullOrWhiteSpace(player.RegistrantNote))
                {
                    <div><strong>Přihlašovatel:</strong> @player.RegistrantNote</div>
                }
            </div>
            @if (currentKingdom is not null)
            {
                <select class="reassign-select form-select form-select-sm mt-1"
                        style="font-size:0.65rem; padding:1px 4px; height:auto;"
                        onchange="reassignPlayer(this, '@player.RegistrationId')">
                    <option value="">Přesunout...</option>
                    <option value="">Nepřidělení</option>
                    @foreach (var k in board!.Kingdoms.Where(k => k.KingdomId != currentKingdom.KingdomId))
                    {
                        <option value="@k.KingdomId">@k.DisplayName</option>
                    }
                </select>
            }
        </div>
    };

    private static string GetPlayerSubTypeLabel(PlayerSubType subType) => subType switch
    {
        Data.PlayerSubType.Pvp => "PvP hráč",
        Data.PlayerSubType.Independent => "Samostatný",
        Data.PlayerSubType.WithRanger => "S hraničářem",
        Data.PlayerSubType.WithParent => "S rodičem",
        _ => subType.ToString()
    };
    [Parameter]
    public int GameId { get; set; }

    [SupplyParameterFromQuery(Name = "assigned")]
    private int? assigned { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? queryError { get; set; }

    private AssignmentBoard? board;
    private string? statusMessage;
    private string? errorMessage;
    private int TotalPlayerCount => board is null ? 0
        : board.UnassignedPlayers.Count + board.Kingdoms.Sum(k => k.CurrentCount);

    protected override async Task OnInitializedAsync()
    {
        board = await KingdomAssignmentService.GetAssignmentBoardAsync(GameId);
    }

    protected override void OnParametersSet()
    {
        statusMessage = assigned == 1 ? "Hráč byl přidělen." : null;
        errorMessage = queryError;
    }

    private static string GetKingdomHeaderStyle(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "background-color: #6c757d; color: white;";
        return $"background-color: {color}; color: white;";
    }

    private static string GetCountBadgeClass(KingdomColumn kingdom)
    {
        if (kingdom.CurrentCount >= kingdom.TargetCount && kingdom.TargetCount > 0)
            return "text-bg-success";
        if (kingdom.CurrentCount > 0)
            return "text-bg-warning";
        return "text-bg-light";
    }
}
