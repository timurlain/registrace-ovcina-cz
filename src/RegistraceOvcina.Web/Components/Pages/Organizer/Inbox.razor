@page "/organizace/posta"
@attribute [Authorize(Policy = AuthorizationPolicies.StaffOnly)]

@using RegistraceOvcina.Web.Data
@using RegistraceOvcina.Web.Features.Email

@inject InboxService InboxService
@inject MailboxSyncService MailboxSyncService
@inject IOptions<MailboxEmailOptions> MailboxOptions

<PageTitle>Pošta</PageTitle>

@if (!MailboxOptions.Value.IsConfigured)
{
    <div class="row g-4">
        <div class="col-12">
            <section class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-3">Příchozí pošta</h1>
                    <div class="alert alert-warning mb-0" role="status">
                        Poštovní schránka není nakonfigurovaná. Nastavte Email sekci v konfiguraci.
                    </div>
                </div>
            </section>
        </div>
    </div>
}
else if (result is null)
{
    <p class="text-secondary">
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        Synchronizuji se schránkou a načítám zprávy...
    </p>
}
else
{
    <div class="row g-4">
        <div class="col-12">
            <section class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
                        <div>
                            <h1 class="h3 mb-2">Pošta</h1>
                            <p class="text-secondary mb-0">Zprávy ze sdílené poštovní schránky.</p>
                        </div>
                        <div class="d-flex gap-2">
                            @if (autoSynced)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis align-self-center">Automaticky synchronizováno</span>
                            }
                            @if (synced == 1)
                            {
                                <span class="badge bg-success align-self-center">Synchronizováno</span>
                            }
                            @if (sent == 1)
                            {
                                <span class="badge bg-success align-self-center">Zpráva byla odeslána.</span>
                            }
                            @if (sendError == 1)
                            {
                                <span class="badge bg-danger align-self-center">Odeslání se nezdařilo.</span>
                            }
                            <form method="post" action="/organizace/posta/sync">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn-outline-primary" data-testid="inbox-sync-button">Synchronizovat</button>
                            </form>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        @if (InboxService.CanReply)
        {
            <div class="col-12">
                <button type="button" class="btn btn-primary mb-3" @onclick="ToggleCompose">
                    @(showCompose ? "Skrýt" : "Nová zpráva")
                </button>

                @if (showCompose)
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h3 class="h5 mb-3">Nová zpráva</h3>
                            <form method="post" action="/organizace/posta/odeslat">
                                <AntiforgeryToken />
                                <div class="mb-3">
                                    <label class="form-label">Příjemce (e-mail)</label>
                                    <input name="ToEmail" type="email" class="form-control" placeholder="jan@example.cz" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Předmět</label>
                                    <input name="Subject" class="form-control" placeholder="Ovčina — ..." required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Text zprávy</label>
                                    <textarea name="Body" class="form-control" rows="5" placeholder="Dobrý den,..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Odeslat</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="col-12">
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <a class="nav-link @(tab == "inbox" ? "active" : "")" href="/organizace/posta?tab=inbox">Příchozí</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(tab == "sent" ? "active" : "")" href="/organizace/posta?tab=sent">Odesláno</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(tab == "all" ? "active" : "")" href="/organizace/posta?tab=all">Vše</a>
                </li>
            </ul>

            <section class="card shadow-sm">
                <div class="card-body p-4">
                    @if (result.Messages.Count == 0)
                    {
                        <div class="empty-state">Žádné zprávy.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle" data-testid="inbox-table">
                                <thead>
                                    <tr>
                                        <th>Datum</th>
                                        <th>Směr</th>
                                        <th>Od</th>
                                        <th>Předmět</th>
                                        <th>Propojeno s</th>
                                        <th>Akce</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var msg in result.Messages)
                                    {
                                        <tr data-testid="@($"inbox-row-{msg.Id}")">
                                            <td class="text-nowrap small">
                                                @(msg.ReceivedAtUtc?.ToLocalTime().ToString("d.M.yyyy H:mm")
                                                    ?? msg.SentAtUtc?.ToLocalTime().ToString("d.M.yyyy H:mm")
                                                    ?? "—")
                                            </td>
                                            <td>
                                                @if (msg.Direction == EmailDirection.Inbound)
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary-emphasis">Příchozí</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success-subtle text-success-emphasis">Odesláno</span>
                                                }
                                            </td>
                                            <td>@msg.From</td>
                                            <td>
                                                <a href="/organizace/posta/@msg.Id" data-testid="@($"inbox-subject-{msg.Id}")">
                                                    @(string.IsNullOrWhiteSpace(msg.Subject) ? "(bez předmětu)" : msg.Subject)
                                                </a>
                                            </td>
                                            <td>
                                                @if (msg.LinkedSubmission is not null)
                                                {
                                                    <span class="badge bg-primary">Přihláška #@msg.LinkedSubmissionId</span>
                                                }
                                                else if (msg.LinkedPerson is not null)
                                                {
                                                    <a href="/organizace/osoby/@msg.LinkedPersonId" class="badge bg-info text-decoration-none">
                                                        @msg.LinkedPerson.LastName @msg.LinkedPerson.FirstName
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary">—</span>
                                                }
                                            </td>
                                            <td>
                                                <a href="/organizace/posta/@msg.Id" class="btn btn-sm btn-outline-secondary">
                                                    Detail
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (result.TotalPages > 1)
                        {
                            <nav aria-label="Stránkování">
                                <ul class="pagination justify-content-center mb-0 mt-3">
                                    <li class="page-item @(result.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link" href="/organizace/posta?tab=@tab&page=@(page - 1)">Předchozí</a>
                                    </li>
                                    @for (var i = 1; i <= result.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == page ? "active" : "")">
                                            <a class="page-link" href="/organizace/posta?tab=@tab&page=@i">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(result.HasNextPage ? "" : "disabled")">
                                        <a class="page-link" href="/organizace/posta?tab=@tab&page=@(page + 1)">Další</a>
                                    </li>
                                </ul>
                            </nav>
                        }
                    }
                </div>
            </section>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "page")]
    private int page { get; set; } = 1;

    [SupplyParameterFromQuery(Name = "tab")]
    private string tab { get; set; } = "inbox";

    [SupplyParameterFromQuery(Name = "synced")]
    private int? synced { get; set; }

    [SupplyParameterFromQuery(Name = "sent")]
    private int? sent { get; set; }

    [SupplyParameterFromQuery(Name = "sendError")]
    private int? sendError { get; set; }

    private InboxPageResult? result;
    private bool showCompose;
    private bool autoSynced;

    private void ToggleCompose()
    {
        showCompose = !showCompose;
    }

    private EmailDirection? GetDirectionFilter() => tab switch
    {
        "sent" => EmailDirection.Outbound,
        "all" => null,
        _ => EmailDirection.Inbound
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!MailboxOptions.Value.IsConfigured)
        {
            return;
        }

        if (page < 1) page = 1;
        if (string.IsNullOrWhiteSpace(tab)) tab = "inbox";

        // Auto-sync on page open. Debounced in MailboxSyncService so repeated
        // navigation within the cooldown window doesn't hammer the Graph API.
        autoSynced = await MailboxSyncService.SyncIfStaleAsync();

        result = await InboxService.GetMessagesAsync(page, directionFilter: GetDirectionFilter());
    }
}
