@page "/organizace/hry/{GameId:int}/qr-stitky"
@attribute [Authorize(Policy = AuthorizationPolicies.StaffOnly)]

@using Microsoft.EntityFrameworkCore
@using QRCoder

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>QR štítky pro hru</PageTitle>

<style>
    /* Fixed 2 col × 4 row A4 portrait grid. Each cell = 105mm × 74.25mm so the
       grid totals exactly 210mm × 297mm = one A4 page. The 70×70mm sticker is
       centered in each cell. No page margins → 8 stickers per A4 sheet. */
    @@page {
        size: A4 portrait;
        margin: 0;
    }

    .sticker-grid {
        display: grid;
        grid-template-columns: 105mm 105mm;
        grid-auto-rows: 74.25mm;
        gap: 0;
        margin: 0 auto;
        padding: 0;
        width: 210mm;
    }

    .sticker-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        break-inside: avoid;
    }

    .sticker {
        box-sizing: border-box;
        width: 70mm;
        height: 70mm;
        border: 1px dashed #ccc;
        padding: 3mm;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 2mm;
    }

    .sticker-character {
        font-weight: 800;
        font-size: 6mm;
        line-height: 1.1;
        color: #000;
        word-break: break-word;
    }

    .sticker-name {
        font-size: 3.5mm;
        line-height: 1.1;
        color: #444;
    }

    .sticker-name .person-id {
        font-size: 2.8mm;
        color: #777;
        font-variant-numeric: tabular-nums;
        margin-left: 1mm;
    }

    .sticker-qr img {
        width: 36mm;
        height: 36mm;
        display: block;
    }

    .print-fab {
        position: fixed;
        top: 12px;
        right: 12px;
        z-index: 1000;
    }

    @@media print {
        .no-print { display: none !important; }
        html, body { margin: 0 !important; padding: 0 !important; }
        .app-header, .app-footer { display: none !important; }
        main, .container { padding: 0 !important; margin: 0 !important; max-width: none !important; }
        .sticker { border-color: #999; }
    }
</style>

@if (game is null)
{
    <p class="text-secondary">Načítám...</p>
}
else
{
    <h1 class="visually-hidden">QR štítky &mdash; @game.Name</h1>

    <button onclick="window.print()" class="btn btn-primary btn-sm no-print print-fab" title="Vytisknout">Vytisknout</button>

    <div class="sticker-grid">
        @foreach (var reg in registrations)
        {
            <div class="sticker-cell">
                <div class="sticker">
                    <div class="sticker-character">@(string.IsNullOrWhiteSpace(reg.CharacterName) ? $"{reg.FirstName} {reg.LastName}" : reg.CharacterName)</div>
                    <div class="sticker-name">@reg.FirstName @reg.LastName <span class="person-id">#@reg.PersonId</span></div>
                    <div class="sticker-qr"><img src="@GenerateQrDataUri(reg.PersonId)" alt="@($"QR kód pro {reg.FirstName} {reg.LastName} (osoba #{reg.PersonId})")" /></div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int GameId { get; set; }

    private Game? game;
    private List<StickerData> registrations = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        game = await db.Games.AsNoTracking().FirstOrDefaultAsync(g => g.Id == GameId);
        if (game is null) return;

        registrations = await db.Registrations
            .AsNoTracking()
            .Where(r => r.Submission.GameId == GameId
                && r.Submission.Status == SubmissionStatus.Submitted
                && r.Status == RegistrationStatus.Active
                && r.AttendeeType == AttendeeType.Player
                && !r.Submission.IsDeleted
                && !r.Person.IsDeleted)
            .OrderBy(r => r.Person.LastName)
            .ThenBy(r => r.Person.FirstName)
            .Select(r => new StickerData(
                r.Person.Id,
                r.Person.FirstName,
                r.Person.LastName,
                r.CharacterName))
            .ToListAsync();
    }

    private string GenerateQrDataUri(int personId)
    {
        var url = $"https://hra.ovcina.cz/p/{personId}";
        using var generator = new QRCodeGenerator();
        using var qrData = generator.CreateQrCode(url, QRCodeGenerator.ECCLevel.M);
        var qrCode = new PngByteQRCode(qrData);
        var pngBytes = qrCode.GetGraphic(5);
        return $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
    }

    private sealed record StickerData(int PersonId, string FirstName, string LastName, string? CharacterName);
}
