@page "/organizace/prihlasky"
@attribute [Authorize(Policy = AuthorizationPolicies.StaffOnly)]

@inject OrganizerSubmissionService OrganizerSubmissionService

<PageTitle>Přihlášky</PageTitle>

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="h3 mb-1">Přihlášky</h1>
        <p class="text-secondary mb-0">Přehled všech přihlášek pro organizátory.</p>
    </div>
    <div>
        <form method="get" class="d-flex align-items-center gap-2 flex-wrap">
            <label class="form-label mb-0 text-nowrap" for="search">Hledat</label>
            <input id="search" name="q" type="text" value="@searchQuery" class="form-control form-control-sm" style="min-width: 150px;" placeholder="Jméno, email..." />
            <label class="form-label mb-0 text-nowrap" for="game-filter">Hra</label>
            <select id="game-filter" name="gameId" class="form-select form-select-sm" style="min-width: 200px;" onchange="this.form.submit()">
                <option value="">Všechny hry</option>
                @if (gameFilters is not null)
                {
                    @foreach (var game in gameFilters)
                    {
                        <option value="@game.Id" selected="@(selectedGameId == game.Id)">@game.Name</option>
                    }
                }
            </select>
            <label class="form-label mb-0 text-nowrap" for="status-filter">Stav</label>
            <select id="status-filter" name="status" class="form-select form-select-sm" style="min-width: 150px;" onchange="this.form.submit()">
                <option value="">Všechny stavy</option>
                <option value="Draft" selected="@(statusFilter == "Draft")">Rozpracovaná</option>
                <option value="Submitted" selected="@(statusFilter == "Submitted")">Odeslaná</option>
                <option value="Cancelled" selected="@(statusFilter == "Cancelled")">Zrušená</option>
            </select>
            @if (!string.IsNullOrEmpty(sortColumn))
            {
                <input type="hidden" name="sort" value="@sortColumn" />
                <input type="hidden" name="dir" value="@sortDir" />
            }
            <button type="submit" class="btn btn-sm btn-outline-primary">Filtrovat</button>
        </form>
    </div>
</div>

@if (deleted == 1)
{
    <div class="alert alert-success" role="status">Přihláška byla smazaná.</div>
}

@if (submissions is null)
{
    <p class="text-secondary">Načítám přihlášky...</p>
}
else if (submissions.Count == 0)
{
    <div class="empty-state">Žádné přihlášky.</div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>@SortLink("game", "Hra")</th>
                    <th>@SortLink("contact", "Kontakt")</th>
                    <th>@SortLink("email", "E-mail")</th>
                    <th>@SortLink("status", "Stav")</th>
                    <th class="text-end">@SortLink("attendees", "Účastníků")</th>
                    <th class="text-end">@SortLink("total", "Celkem")</th>
                    <th>@SortLink("balance", "Platba")</th>
                    <th>@SortLink("submitted", "Odesláno")</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in submissions)
                {
                    <tr style="cursor: pointer;" onclick="window.location.href='/organizace/prihlasky/@s.Id'" data-testid="@($"submission-row-{s.Id}")">
                        <td>@s.GameName</td>
                        <td>@s.PrimaryContactName</td>
                        <td><span class="small">@s.PrimaryEmail</span></td>
                        <td><span class="badge @GetStatusBadgeClass(s.Status)">@GetSubmissionStatusLabel(s.Status)</span></td>
                        <td class="text-end">@s.AttendeeCount</td>
                        <td class="text-end">@s.ExpectedTotalAmount.ToString("0.00") Kč</td>
                        <td><span class="badge @GetBalanceBadgeClass(s.BalanceStatus)">@GetBalanceLabel(s.BalanceStatus)</span></td>
                        <td>@(s.SubmittedAtUtc.HasValue ? CzechTime.Format(s.SubmittedAtUtc.Value) : "—")</td>
                        <td>
                            <form method="post" action="@($"/organizace/prihlasky/{s.Id}/smazat")"
                                  onsubmit="return confirm('Opravdu chcete smazat celou přihlášku? Tuto akci nelze vrátit.');"
                                  onclick="event.stopPropagation();">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn-outline-danger btn-sm" data-testid="@($"delete-submission-{s.Id}")">Smazat</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "gameId")]
    private int? selectedGameId { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    private string? searchQuery { get; set; }

    [SupplyParameterFromQuery(Name = "deleted")]
    private int? deleted { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    private string? statusFilter { get; set; }

    [SupplyParameterFromQuery(Name = "sort")]
    private string? sortColumn { get; set; }

    [SupplyParameterFromQuery(Name = "dir")]
    private string? sortDir { get; set; }

    private IReadOnlyList<OrganizerSubmissionSummary>? submissions;
    private IReadOnlyList<GameFilterItem>? gameFilters;

    protected override async Task OnInitializedAsync()
    {
        gameFilters = await OrganizerSubmissionService.GetGameFilterListAsync();

        // Default to the most recent game when no filter is selected
        if (!selectedGameId.HasValue && gameFilters.Count > 0)
        {
            selectedGameId = gameFilters[0].Id;
        }

        var allSubmissions = await OrganizerSubmissionService.GetSubmissionListAsync(selectedGameId);

        // Apply search filter in memory (small dataset per game)
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = searchQuery.Trim();
            allSubmissions = allSubmissions
                .Where(s => s.PrimaryContactName.Contains(q, StringComparison.OrdinalIgnoreCase)
                    || s.PrimaryEmail.Contains(q, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        // Apply status filter
        if (!string.IsNullOrWhiteSpace(statusFilter) && Enum.TryParse<SubmissionStatus>(statusFilter, out var parsedStatus))
        {
            allSubmissions = allSubmissions.Where(s => s.Status == parsedStatus).ToList();
        }

        // Apply sorting
        submissions = ApplySort(allSubmissions);
    }

    private IReadOnlyList<OrganizerSubmissionSummary> ApplySort(IReadOnlyList<OrganizerSubmissionSummary> items)
    {
        var desc = string.Equals(sortDir, "desc", StringComparison.OrdinalIgnoreCase);

        IEnumerable<OrganizerSubmissionSummary> sorted = sortColumn?.ToLowerInvariant() switch
        {
            "game" => desc ? items.OrderByDescending(s => s.GameName) : items.OrderBy(s => s.GameName),
            "contact" => desc ? items.OrderByDescending(s => s.PrimaryContactName) : items.OrderBy(s => s.PrimaryContactName),
            "email" => desc ? items.OrderByDescending(s => s.PrimaryEmail) : items.OrderBy(s => s.PrimaryEmail),
            "status" => desc ? items.OrderByDescending(s => s.Status) : items.OrderBy(s => s.Status),
            "attendees" => desc ? items.OrderByDescending(s => s.AttendeeCount) : items.OrderBy(s => s.AttendeeCount),
            "total" => desc ? items.OrderByDescending(s => s.ExpectedTotalAmount) : items.OrderBy(s => s.ExpectedTotalAmount),
            "balance" => desc ? items.OrderByDescending(s => s.BalanceStatus) : items.OrderBy(s => s.BalanceStatus),
            "submitted" => desc ? items.OrderByDescending(s => s.SubmittedAtUtc) : items.OrderBy(s => s.SubmittedAtUtc),
            _ => items.OrderByDescending(s => s.SubmittedAtUtc) // default sort
        };

        return sorted.ToList();
    }

    private MarkupString SortLink(string column, string label)
    {
        var isActive = string.Equals(sortColumn, column, StringComparison.OrdinalIgnoreCase);
        var newDir = isActive && string.Equals(sortDir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
        var arrow = isActive ? (string.Equals(sortDir, "desc", StringComparison.OrdinalIgnoreCase) ? " ▾" : " ▴") : "";

        var qs = new List<string>();
        if (selectedGameId.HasValue) qs.Add($"gameId={selectedGameId}");
        if (!string.IsNullOrWhiteSpace(searchQuery)) qs.Add($"q={Uri.EscapeDataString(searchQuery)}");
        if (!string.IsNullOrWhiteSpace(statusFilter)) qs.Add($"status={Uri.EscapeDataString(statusFilter)}");
        qs.Add($"sort={column}");
        qs.Add($"dir={newDir}");

        var href = $"/organizace/prihlasky?{string.Join("&amp;", qs)}";
        return new MarkupString($"<a href=\"{href}\" class=\"text-decoration-none text-dark\">{label}{arrow}</a>");
    }

    private static string GetSubmissionStatusLabel(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Draft => "Rozpracovaná",
        SubmissionStatus.Submitted => "Odeslaná",
        SubmissionStatus.Cancelled => "Zrušená",
        _ => status.ToString()
    };

    private static string GetBalanceLabel(BalanceStatus balanceStatus) => balanceStatus switch
    {
        BalanceStatus.Unpaid => "Neuhrazeno",
        BalanceStatus.Underpaid => "Nedoplatek",
        BalanceStatus.Balanced => "Uhrazeno",
        BalanceStatus.Overpaid => "Přeplatek",
        _ => balanceStatus.ToString()
    };

    private static string GetStatusBadgeClass(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Draft => "text-bg-secondary",
        SubmissionStatus.Submitted => "text-bg-primary",
        SubmissionStatus.Cancelled => "text-bg-danger",
        _ => "text-bg-light"
    };

    private static string GetBalanceBadgeClass(BalanceStatus balance) => balance switch
    {
        BalanceStatus.Unpaid => "text-bg-danger",
        BalanceStatus.Underpaid => "text-bg-warning",
        BalanceStatus.Balanced => "text-bg-success",
        BalanceStatus.Overpaid => "text-bg-info",
        _ => "text-bg-light"
    };
}
