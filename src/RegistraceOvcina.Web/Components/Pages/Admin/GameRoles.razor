@page "/admin/hry/{gameId:int}/role"
@attribute [Authorize(Policy = AuthorizationPolicies.AdminOnly)]

@inject GameRoleService GameRoleService
@inject GameService GameService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Role — @gameName</PageTitle>

<div class="row g-4">
    <div class="col-xl-5">
        <section class="card shadow-sm h-100">
            <div class="card-body p-4">
                <h1 class="h3 mb-2">Role — @gameName</h1>
                <p class="text-secondary">Správa herních rolí pro uživatele v této hře.</p>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="alert alert-success" role="status">@statusMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger" role="alert">@errorMessage</div>
                }

                <h2 class="h5 mt-4 mb-3">Přidělit roli</h2>
                <form method="post" @formname="assign-role" @onsubmit="AssignRoleAsync">
                    <AntiforgeryToken />
                    <div class="mb-3">
                        <label class="form-label" for="role-email">E-mail uživatele</label>
                        <input id="role-email" @bind="assignEmail" class="form-control" placeholder="uzivatel@example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="role-name">Role</label>
                        <select id="role-name" @bind="assignRole" class="form-select">
                            <option value="">-- vyberte --</option>
                            @foreach (var r in availableRoles)
                            {
                                <option value="@r">@r</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Přidělit roli</button>
                </form>

                <hr class="my-4" />

                <form method="post" @formname="seed-roles" @onsubmit="SeedRolesAsync">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-secondary w-100">Odvodit z registrací</button>
                </form>
            </div>
        </section>
    </div>

    <div class="col-xl-7">
        <section class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Přidělené role</h2>

                @if (usersWithRoles is null)
                {
                    <p class="text-secondary">Načítám...</p>
                }
                else if (usersWithRoles.Count == 0)
                {
                    <div class="empty-state">Zatím nejsou přidělené žádné role.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Jméno</th>
                                    <th>E-mail</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in usersWithRoles)
                                {
                                    <tr>
                                        <td class="fw-semibold small">@user.DisplayName</td>
                                        <td class="small text-secondary">@user.Email</td>
                                        <td>
                                            @foreach (var role in user.Roles)
                                            {
                                                <span class="badge bg-secondary me-1">
                                                    @role
                                                    <button type="button" class="btn-close btn-close-white ms-1" style="font-size:0.5rem;"
                                                            @onclick="() => RevokeRoleAsync(user.Email, role)" title="Odebrat"></button>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Dospělí a pomocníci — přidělit roli</h2>
                <p class="text-secondary small mb-3">Hráči (děti) jsou přiděleni do království, dospělí dostávají herní role.</p>

                @if (registeredAttendees is null)
                {
                    <p class="text-secondary">Načítám...</p>
                }
                else if (registeredAttendees.Count == 0)
                {
                    <div class="empty-state">Žádní registrovaní účastníci pro tuto hru.</div>
                }
                else
                {
                    <div class="table-responsive" style="max-height: 50vh; overflow-y: auto;">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="sticky-top bg-white">
                                <tr>
                                    <th>Jméno</th>
                                    <th>Typ</th>
                                    <th>Aktuální role</th>
                                    <th>Přidělit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ bool shownPlayerDivider = false; }
                                @foreach (var att in registeredAttendees)
                                {
                                    @if (att.IsPlayer && !shownPlayerDivider)
                                    {
                                        shownPlayerDivider = true;
                                        <tr><td colspan="4" class="text-secondary small border-top pt-2 pb-1"><em>Hráči (přidělení přes Rozdělení do království)</em></td></tr>
                                    }
                                    <tr class="@(att.IsPlayer ? "opacity-50" : "")">
                                        <td>
                                            <div class="fw-semibold small">@att.PersonName</div>
                                            <div class="text-secondary" style="font-size:0.7rem;">@att.Email</div>
                                        </td>
                                        <td>
                                            <span class="badge @(att.IsPlayer ? "text-bg-primary" : "text-bg-secondary")" style="font-size:0.7rem;">
                                                @(att.IsPlayer ? "Hráč" : "Dospělý")
                                            </span>
                                        </td>
                                        <td>
                                            @if (att.CurrentRoles.Count > 0)
                                            {
                                                @foreach (var r in att.CurrentRoles)
                                                {
                                                    <span class="badge bg-info me-1" style="font-size:0.65rem;">@r</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(att.Email))
                                            {
                                                <div class="d-flex gap-1">
                                                    <select class="form-select form-select-sm" style="font-size:0.75rem; min-width:100px;"
                                                            @bind="att.SelectedRole">
                                                        <option value="">--</option>
                                                        @foreach (var r in availableRoles)
                                                        {
                                                            @if (!att.CurrentRoles.Contains(r))
                                                            {
                                                                <option value="@r">@r</option>
                                                            }
                                                        }
                                                    </select>
                                                    <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:0.7rem;"
                                                            disabled="@string.IsNullOrEmpty(att.SelectedRole)"
                                                            @onclick="() => QuickAssignAsync(att)">+</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Bez e-mailu</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@code {
    [Parameter]
    public int GameId { get; set; }

    private static readonly string[] availableRoles =
        ["player", "npc", "king", "merchant", "ranger-leader", "tech-support", "organizer"];

    private string gameName = "";
    private List<UserWithRoles>? usersWithRoles;
    private List<AttendeeRoleRow>? registeredAttendees;
    private string assignEmail = "";
    private string assignRole = "";
    private string? statusMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var game = await GameService.GetGameForEditAsync(GameId);
        gameName = game?.Name ?? $"Hra #{GameId}";
        await LoadRolesAsync();
        await LoadAttendeesAsync();
    }

    private async Task LoadRolesAsync()
    {
        usersWithRoles = await GameRoleService.GetAllRolesForGameAsync(GameId);
    }

    private async Task LoadAttendeesAsync()
    {
        registeredAttendees = await GameRoleService.GetRegisteredAttendeesForGameAsync(GameId);
        // Populate current roles from usersWithRoles
        if (usersWithRoles is not null && registeredAttendees is not null)
        {
            var roleLookup = usersWithRoles.ToDictionary(u => u.Email.ToLower(), u => u.Roles);
            foreach (var att in registeredAttendees)
            {
                if (!string.IsNullOrWhiteSpace(att.Email) && roleLookup.TryGetValue(att.Email.ToLower(), out var roles))
                {
                    att.CurrentRoles = roles;
                }
            }
        }
    }

    private async Task QuickAssignAsync(AttendeeRoleRow att)
    {
        if (string.IsNullOrWhiteSpace(att.Email) || string.IsNullOrWhiteSpace(att.SelectedRole))
            return;

        statusMessage = null;
        errorMessage = null;

        try
        {
            var currentUser = await GetCurrentUserIdAsync();
            await GameRoleService.AssignRoleAsync(att.Email, GameId, att.SelectedRole, currentUser);
            statusMessage = $"Role '{att.SelectedRole}' přidělena: {att.PersonName}";
            att.CurrentRoles.Add(att.SelectedRole);
            att.SelectedRole = "";
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task AssignRoleAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(assignEmail) || string.IsNullOrWhiteSpace(assignRole))
        {
            errorMessage = "Vyplňte e-mail i roli.";
            return;
        }

        try
        {
            var currentUser = await GetCurrentUserIdAsync();
            await GameRoleService.AssignRoleAsync(assignEmail.Trim(), GameId, assignRole, currentUser);
            statusMessage = $"Role '{assignRole}' přidělena uživateli {assignEmail}.";
            assignEmail = "";
            assignRole = "";
            await LoadRolesAsync();
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task RevokeRoleAsync(string email, string role)
    {
        statusMessage = null;
        errorMessage = null;

        try
        {
            var currentUser = await GetCurrentUserIdAsync();
            await GameRoleService.RevokeRoleAsync(email, GameId, role, currentUser);
            statusMessage = $"Role '{role}' odebrána uživateli {email}.";
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task SeedRolesAsync()
    {
        statusMessage = null;
        errorMessage = null;

        try
        {
            var currentUser = await GetCurrentUserIdAsync();
            var count = await GameRoleService.SeedRolesFromRegistrationsAsync(GameId, currentUser);
            statusMessage = count > 0
                ? $"Odvozeno {count} nových rolí z registrací."
                : "Žádné nové role nebyly odvozeny.";
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private async Task<string> GetCurrentUserIdAsync()
    {
        if (AuthState is null)
            throw new InvalidOperationException("Authentication state not available.");

        var state = await AuthState;
        var user = await UserManager.GetUserAsync(state.User);
        return user?.Id ?? throw new InvalidOperationException("User not found.");
    }
}
