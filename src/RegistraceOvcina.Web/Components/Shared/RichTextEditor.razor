@inject IJSRuntime JS
@implements IAsyncDisposable

<div>
    <ul class="nav nav-tabs mb-0">
        <li class="nav-item">
            <button class="nav-link @(activeTab == Tab.Html ? "active" : "")" type="button" @onclick="() => SwitchTab(Tab.Html)">HTML</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == Tab.Preview ? "active" : "")" type="button" @onclick="() => SwitchTab(Tab.Preview)">Náhled</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == Tab.Editor ? "active" : "")" type="button" @onclick="() => SwitchTab(Tab.Editor)">Editor</button>
        </li>
    </ul>

    @if (activeTab == Tab.Html)
    {
        <textarea class="form-control font-monospace border-top-0 rounded-top-0"
                  rows="15"
                  style="min-height: @(MinHeight)px;"
                  @bind="sourceHtml"
                  @bind:event="oninput"></textarea>
    }

    @if (activeTab == Tab.Preview)
    {
        <div class="border border-top-0 rounded-bottom p-3" style="min-height: @(MinHeight)px; background: #fff;">
            @if (string.IsNullOrWhiteSpace(sourceHtml))
            {
                <p class="text-secondary fst-italic mb-0">Zatím prázdné — přepněte na záložku HTML a vložte obsah.</p>
            }
            else
            {
                @((MarkupString)sourceHtml)
            }
        </div>
    }

    <div style="@(activeTab == Tab.Editor ? "" : "position:absolute;left:-9999px;height:0;overflow:hidden;")">
        <div id="@toolbarId">
            <span class="ql-formats">
                <select class="ql-header">
                    <option value="2"></option>
                    <option value="3"></option>
                    <option selected></option>
                </select>
            </span>
            <span class="ql-formats">
                <button class="ql-bold"></button>
                <button class="ql-italic"></button>
                <button class="ql-underline"></button>
            </span>
            <span class="ql-formats">
                <button class="ql-list" value="ordered"></button>
                <button class="ql-list" value="bullet"></button>
            </span>
            <span class="ql-formats">
                <button class="ql-link"></button>
            </span>
            <span class="ql-formats">
                <button class="ql-clean"></button>
            </span>
        </div>
        <div id="@editorId" style="min-height: @(MinHeight)px;"></div>
    </div>
</div>

@code {
    private enum Tab { Html, Preview, Editor }

    private string editorId = $"quill-editor-{Guid.NewGuid():N}"[..24];
    private string toolbarId = $"quill-toolbar-{Guid.NewGuid():N}"[..25];
    private bool initialized;
    private Tab activeTab = Tab.Html;
    private string sourceHtml = "";

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public int MinHeight { get; set; } = 200;

    protected override void OnInitialized()
    {
        sourceHtml = Value ?? "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("quillInterop.create", editorId, toolbarId, Value);
            initialized = true;
        }
    }

    private async Task SwitchTab(Tab tab)
    {
        // Sync content from current tab before switching
        if (activeTab == Tab.Editor && initialized)
        {
            sourceHtml = await JS.InvokeAsync<string>("quillInterop.getHtml", editorId);
        }

        activeTab = tab;

        // Load content into target tab
        if (tab == Tab.Editor && initialized)
        {
            StateHasChanged();
            await Task.Delay(50);
            await JS.InvokeVoidAsync("quillInterop.setHtml", editorId, sourceHtml);
        }
    }

    public async Task<string> GetHtmlAsync()
    {
        if (activeTab == Tab.Editor && initialized)
        {
            sourceHtml = await JS.InvokeAsync<string>("quillInterop.getHtml", editorId);
        }

        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(sourceHtml);
        }
        return sourceHtml;
    }

    public async Task SetHtmlAsync(string html)
    {
        sourceHtml = html;
        if (initialized)
        {
            await JS.InvokeVoidAsync("quillInterop.setHtml", editorId, html);
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
