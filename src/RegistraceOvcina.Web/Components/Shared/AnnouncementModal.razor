@using System.Security.Claims
@using RegistraceOvcina.Web.Features.Announcements

@inject AnnouncementService AnnouncementService
@inject AuthenticationStateProvider AuthenticationStateProvider

@if (announcement is not null)
{
    <div class="announcement-overlay">
        <div class="announcement-card">
            <h2 class="announcement-title">@announcement.Title</h2>
            <div class="text-secondary small mb-3">
                @announcement.CreatedAtUtc.ToLocalTime().ToString("d. M. yyyy")
            </div>
            <div class="announcement-content">
                @((MarkupString)announcement.HtmlContent)
            </div>
            <div class="text-center mt-4">
                <button class="btn btn-primary btn-lg" @onclick="DismissAsync">Pokračovat</button>
            </div>
        </div>
    </div>
}

@code {
    private Announcement? announcement;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (userId is not null)
        {
            announcement = await AnnouncementService.GetUnseenAnnouncementAsync(userId);
        }
    }

    private async Task DismissAsync()
    {
        if (announcement is null || userId is null) return;
        await AnnouncementService.DismissAsync(announcement.Id, userId);
        announcement = null;
    }
}
