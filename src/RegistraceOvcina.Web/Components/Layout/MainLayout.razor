@using System.Reflection
@using System.Security.Claims
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="app-shell">
    @if (isInteractive)
    {
        <span data-testid="interactive-ready" hidden></span>
    }

    <header class="app-header sticky-top">
        <div class="container py-3 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div class="d-flex flex-column">
                <a class="brand-link" href="/">Ovčina registrace</a>
                <span class="text-secondary header-subtitle">Přihlášky skupin a rodin, platby a minulé účasti, vše v jednom místě.</span>
            </div>

            <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3">
                <nav class="d-flex flex-wrap gap-3">
                    <a class="nav-link" href="/">Domů</a>
                    <AuthorizeView>
                        <Authorized>
                            <a class="nav-link" href="/moje-prihlasky">Moje přihlášky</a>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="@StaffRoles">
                        <Authorized>
                            <a class="nav-link" href="/organizace/prihlasky">Přihlášky</a>
                            <a class="nav-link" href="/organizace/platby">Platby</a>
                            <a class="nav-link" href="/organizace/rozdeleni">Království</a>
                            <a class="nav-link" href="/organizace/role">Role</a>
                            <a class="nav-link" href="/organizace/strava">Strava</a>
                            <a class="nav-link" href="/organizace/posta">Pošta</a>
                            <span class="nav-divider"></span>
                            <a class="nav-link" href="/organizace/osoby">Osoby</a>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="@RoleNames.Admin">
                        <Authorized>
                            <a class="nav-link" href="/admin/hry">Hry</a>
                            <a class="nav-link" href="/admin/kralovstvi">Správa království</a>
                            <a class="nav-link" href="/admin/organizatori">Organizátoři</a>
                        </Authorized>
                    </AuthorizeView>
                </nav>

                <AuthorizeView>
                    <Authorized Context="authState">
                        <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                            <span class="small">@GetUserLabel(authState.User)</span>
                            <form method="post" action="/Account/Logout" class="d-inline">
                                <AntiforgeryToken />
                                <input type="hidden" name="returnUrl" value="@GetReturnUrl()" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm" data-testid="logout-button">Odhlásit</button>
                            </form>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-outline-primary btn-sm"
                                    data-testid="header-login-button"
                                    @onclick="NavigateToLogin">
                                Přihlášení
                            </button>
                            <button type="button"
                                    class="btn btn-primary btn-sm"
                                    data-testid="header-register-button"
                                    @onclick="NavigateToRegister">
                                Vytvořit účet
                            </button>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="container py-4">
        <AnnouncementModal />
        @Body
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center py-3">
            <span>&copy; @DateTime.Today.Year Ovčina <span class="small text-secondary">v@(AppVersion)</span></span>
            <a href="/zasady-ochrany-osobnich-udaju">Ochrana osobních údajů</a>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Došlo k neočekávané chybě.
    <a href="." class="reload">Načíst znovu</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string StaffRoles = $"{RoleNames.Admin},{RoleNames.Organizer}";
    private static readonly string AppVersion = typeof(Program).Assembly
        .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>()?.InformationalVersion?.Split('+')[0] ?? "dev";
    private bool isInteractive;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || isInteractive)
        {
            return;
        }

        isInteractive = true;
        StateHasChanged();
    }

    private string GetReturnUrl()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return string.IsNullOrWhiteSpace(relative) ? string.Empty : relative;
    }

    private void NavigateToLogin() => NavigationManager.NavigateTo("/Account/Login", forceLoad: true);

    private void NavigateToRegister() => NavigationManager.NavigateTo("/Account/Register", forceLoad: true);

    private static string GetUserLabel(ClaimsPrincipal user) =>
        user.Identity?.Name
        ?? user.FindFirst("name")?.Value
        ?? "uživatel";
}
