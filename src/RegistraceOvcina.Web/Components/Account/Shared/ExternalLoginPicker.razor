@using Microsoft.AspNetCore.Authentication
@using RegistraceOvcina.Web.Data

@inject SignInManager<ApplicationUser> SignInManager

@if (externalLogins.Length == 0)
{
    <p class="text-secondary mb-0">
        V tomto prostředí zatím nejsou nakonfigurovaní externí poskytovatelé.
        Připravujeme přihlášení přes Microsoft, Google a Seznam.
    </p>
}
else
{
    <form class="d-flex flex-column gap-2" action="/Account/PerformExternalLogin" method="post">
        <AntiforgeryToken />
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

        @foreach (var provider in externalLogins)
        {
            <button type="submit" class="btn-oauth" name="provider" value="@provider.Name" title="Přihlásit se přes @provider.DisplayName">
                @((MarkupString)GetProviderIcon(provider.Name))
                @provider.DisplayName
            </button>
        }
    </form>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }

    private static string GetProviderIcon(string providerName) => providerName switch
    {
        "Microsoft" => """<svg width="20" height="20" viewBox="0 0 21 21"><rect x="1" y="1" width="9" height="9" fill="#F25022"/><rect x="11" y="1" width="9" height="9" fill="#7FBA00"/><rect x="1" y="11" width="9" height="9" fill="#00A4EF"/><rect x="11" y="11" width="9" height="9" fill="#FFB900"/></svg>""",
        "Google" => """<svg width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>""",
        "Seznam" => """<svg width="20" height="20" viewBox="0 0 48 48"><circle cx="24" cy="24" r="22" fill="#CC0000"/><text x="24" y="32" text-anchor="middle" fill="white" font-family="Arial,sans-serif" font-weight="bold" font-size="28">S</text></svg>""",
        _ => """<svg width="20" height="20" viewBox="0 0 20 20"><circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="1.5"/><text x="10" y="14" text-anchor="middle" fill="currentColor" font-size="11">?</text></svg>"""
    };
}
