@page "/Account/Login"

@using Microsoft.AspNetCore.Authentication
@using RegistraceOvcina.Web.Data
@using RegistraceOvcina.Web.Features.Auth

@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject GuestAuthService GuestAuthService

<PageTitle>Přihlášení</PageTitle>

<div class="auth-container">
    <section class="auth-card">
        <h1>Přihlášení</h1>

        @if (linkSent == "1")
        {
            <div class="alert alert-success" role="status">
                Odkaz k přihlášení byl odeslán na váš e-mail. Odkaz je platný 60 minut.
            </div>
        }

        @if (error == "invalid-token")
        {
            <div class="alert alert-danger" role="alert">
                Odkaz je neplatný nebo vypršel. Zkuste to prosím znovu.
            </div>
        }
        else if (error == "create-failed")
        {
            <div class="alert alert-danger" role="alert">
                Nepodařilo se vytvořit účet. Zkuste to prosím znovu.
            </div>
        }
        else if (error == "send-failed")
        {
            <div class="alert alert-danger" role="alert">
                Nepodařilo se odeslat přihlašovací odkaz. Zkuste to prosím znovu nebo se přihlaste jiným způsobem.
            </div>
        }

        <p class="text-warm" style="text-align:center;">Zadejte svůj e-mail a my vám pošleme přihlašovací odkaz.</p>

        <form method="post" action="/Account/RequestMagicLink">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="mb-3">
                <label for="email" class="form-label">E-mail</label>
                <input id="email" name="email" type="email" class="form-control" autocomplete="username"
                       placeholder="rodic@example.cz" required data-testid="login-email" />
            </div>

            <button type="submit" class="btn btn-primary w-100" data-testid="login-submit">Přihlásit se</button>
        </form>

        <div class="auth-divider">nebo se přihlaste přes</div>

        <ExternalLoginPicker />

        @if (GuestAuthService.IsEnabled)
        {
            <div class="auth-divider">nebo</div>

            <a href="/Account/GuestLogin@(ReturnUrl is not null ? $"?ReturnUrl={Uri.EscapeDataString(ReturnUrl)}" : "")"
               class="btn btn-outline-secondary w-100" data-testid="guest-login-link">
                Přihlásit se jako host
            </a>
        }
    </section>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "linkSent")]
    private string? linkSent { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }
}
